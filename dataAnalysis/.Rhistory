data_lmEasy <- data%>%filter(treatment=="easy")
p1 <- plotFunction(data_plot, data, span[[1]])
p2 <- plotFunction(data_plot, data, span[[2]])
p3 <- plotFunction(data_plot, data, span[[3]])
p4 <- plotFunction(data_plot, data, span[[4]])
